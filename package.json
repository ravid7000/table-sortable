{
  "name": "table-sortable",
  "version": "2.0.3",
  "description": "A jquery plugin to sort and paginate data in table form",
  "main": "dist/table-sortable.js",
  "engines": {
    "node": ">=18.x"
  },
  "repository": {
    "url": "https://github.com/ravid7000/table-sortable",
    "type": "git"
  },
  "scripts": {
    "start": "vite",
    "bundle": "vite build",
    "postbundle": "node ./scripts/postbundle.js",
    "publish": "node ./scripts/publish.js",
    "prepublish": "npm run bundle",
    "test": "node scripts/test.js"
  },
  "author": "Ravi Dhiman",
  "license": "MIT",
  "browserslist": [
    ">1%",
    "last 4 versions",
    "Firefox > 20",
    "Chrome > 20",
    "Opera > 20",
    "not ie <= 7"
  ],
  "dependencies": {
    "@babel/core": "7.2.2",
    "@typescript-eslint/eslint-plugin-tslint": "^1.4.2",
    "babel-eslint": "9.0.0",
    "babel-jest": "^25.0.0",
    "classnames": "^2.2.6",
    "eslint": "5.12.0",
    "eslint-config-prettier": "^4.1.0",
    "eslint-loader": "2.1.1",
    "eslint-plugin-import": "2.14.0",
    "eslint-plugin-prettier": "^3.0.1",
    "fs-extra": "7.0.1",
    "jquery": "^3.3.1",
    "prettier": "^1.16.4"
  },
  "devDependencies": {
    "@vitejs/plugin-legacy": "^5.0.0",
    "gh-pages": "^2.2.0",
    "jest": "^25.1.0",
    "jest-watch-typeahead": "^0.2.1",
    "sass": "^1.70.0",
    "tslint": "^5.13.1",
    "typescript": "^3.3.3333",
    "vite": "^5.0.0"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "resolver": "jest-pnp-resolver",
    "setupFiles": [
      "react-app-polyfill/jsdom"
    ],
    "testMatch": [
      "<rootDir>/src/**/__tests__/**/*.{js,jsx,ts,tsx}",
      "<rootDir>/src/**/?(*.)(spec|test).{js,jsx,ts,tsx}"
    ],
    "testEnvironment": "jsdom",
    "testURL": "http://localhost",
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "<rootDir>/node_modules/babel-jest",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "[/\\\\]node_modules[/\\\\].+\\.(js|jsx|ts|tsx)$",
      "^.+\\.module\\.(css|sass|scss)$"
    ],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  },
  "babel": {
    "presets": [
      "react-app"
    ]
  },
  "eslintConfig": {
    "extends": "react-app"
  }
}
